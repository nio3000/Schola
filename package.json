{
  "name": "schola",
  "version": "1.0.0",
  "private": true,
  "description": "Schola local-first knowledge workbench Phase 0 scaffold.",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 npm run electron:dev\"",
    "electron:dev": "npm run build:electron && electron dist-electron/electron/main.js",
    "build:renderer": "vite build",
    "build:renderer:e2e": "cross-env NODE_ENV=development vite build --mode development",
    "build:electron": "tsc -p tsconfig.node.json",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist','dist-electron','release']) { try { fs.rmSync(p,{recursive:true,force:true}) } catch(_) {} }\"",
    "build": "npm run clean && npm run build:electron && npm run build:renderer",
    "package": "npm run build && electron-builder --win --x64",
    "package:dir": "npm run build && electron-builder --win --x64 --dir",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "test:e2e": "npm run build:electron && playwright test"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-react": "latest",
    "chokidar": "^3.6.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.2",
    "ecc-universal": "^1.10.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "marked": "^18.0.3",
    "pdfjs-dist": "~5.7.284",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "^42.1.0",
    "electron-builder": "^26.0.0",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "jsdom": "^29.1.1",
    "playwright": "latest",
    "prettier": "latest",
    "typescript-eslint": "latest",
    "vitest": "^4.1.7",
    "wait-on": "latest"
  },
  "build": {
    "appId": "com.schola.app",
    "productName": "Schola",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/electron/**/*",
      "dist-electron/src/lib/**/*.js",
      "package.json",
      "!dist-electron/tests/**/*",
      "!dist-electron/**/*.test.js",
      "!dist-electron/**/*.spec.js",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "node_modules/pdfjs-dist/legacy/build/pdf.worker.min.mjs",
        "to": "pdfjs-worker/pdf.worker.min.mjs"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
